# ═══════════════════════════════════════════════════════════════════════════
# Karri Prasad AI Operations Dashboard — Environment Variables Template
# Copy to .env for local development (never commit .env to git)
# ═══════════════════════════════════════════════════════════════════════════

# ─── AI / LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...your_groq_api_key_here...

# Apply pipeline uses Anthropic when set (sonnet = tailoring, haiku = extraction/
# classification); falls back to Groq when blank.
# For a 100%-FREE setup: leave ANTHROPIC_API_KEY blank (or set LLM_PROVIDER=groq)
# and rely on GROQ_API_KEY above.
ANTHROPIC_API_KEY=
ANTHROPIC_SMART_MODEL=claude-sonnet-5
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
# Force a provider regardless of keys: "groq" (free) or "anthropic". Blank = auto.
LLM_PROVIDER=

# ─── Apply pipeline files ─────────────────────────────────────────────────────
# Where uploaded resume PDFs are stored. Render disk is ephemeral — parsed
# content and the fact bank live in Postgres, so a wipe only loses the raw PDF.
UPLOADS_DIR=./uploads

# ─── Auto-apply worker (Phase 3) ──────────────────────────────────────────────
# Sealed-box keypair for Workday credentials: `python3 crypto_box.py keygen`
# Web service gets ONLY the public key; the worker gets both.
ATS_CREDS_PUBLIC_KEY=
ATS_CREDS_PRIVATE_KEY=
# Worker knobs — run locally with PW_HEADLESS=false to solve CAPTCHAs yourself
PW_HEADLESS=true
WORKER_POLL_SECONDS=5
CAPTCHA_WAIT_SECONDS=600
PW_PROFILE_DIR=./uploads/pw_profile

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL on Render (auto-filled by render.yaml)
# Leave blank to use local SQLite (sessions.db)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-here-change-me-in-production

# Dashboard admin credentials (first-run seed)
ADMIN_EMAIL=admin@karriprasad.ai
ADMIN_PASSWORD=changeme123

# JWT expiry in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Error tracking (Phase 6, optional) ──────────────────────────────────────
# Leave blank to disable. Set to your Sentry project DSN to capture exceptions.
SENTRY_DSN=

# ─── Reports ─────────────────────────────────────────────────────────────────
# Directory to store generated report files
REPORTS_DIR=/tmp/reports

# ─── Telegram Instant Alerts (optional) ──────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message your bot once, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Gmail read-only routing (Phase 5) ───────────────────────────────────────
# Preferred: OAuth with the gmail.readonly scope (cannot send or modify mail).
#   1. Google Cloud console → OAuth client (Desktop) → client id + secret
#   2. Consent with scope https://www.googleapis.com/auth/gmail.readonly
#   3. Exchange the code for a refresh token, set it below
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
# Fallback (zero-setup): read-only IMAP with a Gmail app password.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Email Notifications (optional) ──────────────────────────────────────────
# Leave blank to disable email sending (notifications still stored in DB)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@karriprasad.ai
